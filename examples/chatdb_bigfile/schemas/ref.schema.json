{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://exonware.com/schemas/chatdb/ref.schema.json",
  "title": "Internal reference object",
  "type": "object",
  "additionalProperties": false,
  "required": ["$ref"],
  "properties": {
    "$ref": {
      "type": "string",
      "pattern": "^xwdb://[A-Za-z0-9_\-]+/[A-Za-z0-9_\-]+$"
    }
  }
}
