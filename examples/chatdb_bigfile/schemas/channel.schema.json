{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://exonware.com/schemas/chatdb/channel.schema.json",
  "title": "Channel payload",
  "type": "object",
  "additionalProperties": true,
  "required": ["name", "owner"],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "owner": { "$ref": "./ref.schema.json" },
    "admins": {
      "type": "array",
      "items": { "$ref": "./ref.schema.json" }
    },
    "member_count": { "type": "integer" },
    "permissions": { "type": "object" }
  }
}
