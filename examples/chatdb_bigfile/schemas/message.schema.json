{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://exonware.com/schemas/chatdb/message.schema.json",
  "title": "Message payload",
  "type": "object",
  "additionalProperties": true,
  "required": ["chat", "author", "text"],
  "properties": {
    "chat": { "$ref": "./ref.schema.json" },
    "author": { "$ref": "./ref.schema.json" },
    "text": { "type": "string" },
    "reply_to": {
      "nullable": true,
      "type": "object"
    },
    "views": { "type": "integer" },
    "edited_ts": { "nullable": true },
    "version": { "type": "integer" }
  }
}
