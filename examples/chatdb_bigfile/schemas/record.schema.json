{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://exonware.com/schemas/chatdb/record.schema.json",
  "title": "ChatDB JSONL record envelope",
  "type": "object",
  "additionalProperties": false,
  "required": ["@type", "id", "ts", "payload"],
  "properties": {
    "@type": {
      "type": "string",
      "enum": ["User", "Channel", "Group", "Message", "Reaction"]
    },
    "id": { "type": "string", "minLength": 1 },
    "ts": { "type": "integer" },
    "payload": { "type": "object" }
  }
}
